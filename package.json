{
  "name": "stm32-cmake-build-manager",
  "displayName": "STM32 CMake Build Manager",
  "description": "Manage CMake build lists of projects generated by STM32CubeMX. Provides commands to add/remove source files and header paths to/from CMakeLists.txt, with user-friendly context menu integration and a tree view for build list management.",
  "version": "1.0.1",
  "icon": "media/stm32-build.png",
  "publisher": "COITSILLE",
  "repository": {
    "type": "git",
    "url": "https://github.com/COITSILLE/stm32-one-click-cmakelists.git"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:CMakeLists.txt",
    "workspaceContains:*.ioc"
  ],
  "main": "./extension.js",
  "extensionDependencies": [
    "ms-vscode.cmake-tools"
  ],
  "contributes": {
    "commands": [
      {
        "command": "stm32-cmake-build-list-manager.addSourceFile",
        "title": "Add source to build"
      },
      {
        "command": "stm32-cmake-build-list-manager.addFolderHeaderPath",
        "title": "Add header path"
      },
      {
        "command": "stm32-cmake-build-list-manager.addFolderSourceAndHeader",
        "title": "Add source and header of this folder"
      },
      {
        "command": "stm32-cmake-build-list-manager.addFolderRecursiveSourceAndHeader",
        "title": "Recursively add source and header of this folder"
      },
      {
        "command": "stm32-cmake-build-list-manager.removeSourceFile",
        "title": "Remove source from build"
      },
      {
        "command": "stm32-cmake-build-list-manager.removeHeaderPath",
        "title": "Remove header search path"
      },
      {
        "command": "stm32-cmake-build-list-manager.removeFolderSourceAndHeader",
        "title": "Remove source and header of this folder"
      },
      {
        "command": "stm32-cmake-build-list-manager.removeFolderRecursiveSourceAndHeader",
        "title": "Recursively remove source and header of this folder"
      },
      {
        "command": "stm32-cmake-build-list-manager.rebuildUserListsFromWorkspace",
        "title": "STM32 CMake Build Manager: Rebuild USER_SOURCES/USER_HEADERS"
      },
      {
        "command": "stm32-cmake-build-list-manager.syncCubeMxLockDirs",
        "title": "STM32 CMake Build Manager: Sync CubeMX Paths To lockDirs"
      },
      {
        "command": "stm32-cmake-build-list-manager.clearUserLists",
        "title": "STM32 CMake Build Manager: Clear USER_SOURCES/USER_HEADERS"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceScheme == file && (resourceExtname == .c || resourceExtname == .cpp)",
          "command": "stm32-cmake-build-list-manager.addSourceFile",
          "group": "1_stm32_add"
        },
        {
          "when": "resourceScheme == file && (resourceExtname == .c || resourceExtname == .cpp)",
          "command": "stm32-cmake-build-list-manager.removeSourceFile",
          "group": "2_stm32_remove"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.addFolderHeaderPath",
          "group": "1_stm32_add"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.addFolderSourceAndHeader",
          "group": "1_stm32_add"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.addFolderRecursiveSourceAndHeader",
          "group": "1_stm32_add"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.removeHeaderPath",
          "group": "2_stm32_remove"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.removeFolderSourceAndHeader",
          "group": "2_stm32_remove"
        },
        {
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "command": "stm32-cmake-build-list-manager.removeFolderRecursiveSourceAndHeader",
          "group": "2_stm32_remove"
        }
      ],
      "view/item/context": [
        {
          "when": "view == stm32BuildView && viewItem == stm32BuildSource",
          "command": "stm32-cmake-build-list-manager.removeSourceFile",
          "group": "2_stm32_remove"
        },
        {
          "when": "view == stm32BuildView && viewItem == stm32BuildFolder",
          "command": "stm32-cmake-build-list-manager.removeHeaderPath",
          "group": "2_stm32_remove"
        },
        {
          "when": "view == stm32BuildView && viewItem == stm32BuildFolder",
          "command": "stm32-cmake-build-list-manager.removeFolderSourceAndHeader",
          "group": "2_stm32_remove"
        },
        {
          "when": "view == stm32BuildView && viewItem == stm32BuildFolder",
          "command": "stm32-cmake-build-list-manager.removeFolderRecursiveSourceAndHeader",
          "group": "2_stm32_remove"
        }
      ],
      "commandPalette": [
        {
          "command": "stm32-cmake-build-list-manager.rebuildUserListsFromWorkspace"
        },
        {
          "command": "stm32-cmake-build-list-manager.syncCubeMxLockDirs"
        },
        {
          "command": "stm32-cmake-build-list-manager.clearUserLists"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "stm32BuildView",
          "name": "STM32 Build List",
          "contextualTitle": "STM32"
        }
      ]
    },
    "configuration": {
      "title": "STM32 CMake Build List Manager",
      "properties": {
        "stm32-cmake-build-list-manager.lockDirs": {
          "type": "array",
          "default": [],
          "description": "Locked folder rules used by all add/remove/rebuild path filtering logic. Supports two entry formats: string (recursive user rule) or object ({ path, mode: exact|recursive, group }).",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "Workspace-relative folder path, such as Drivers/CMSIS."
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "exact",
                      "recursive"
                    ],
                    "default": "recursive",
                    "description": "exact: only this folder; recursive: this folder and all descendants."
                  },
                  "group": {
                    "type": "string",
                    "default": "User",
                    "description": "Group label for organizing rules (for example User, ThirdParty, CubeMX Auto)."
                  }
                },
                "additionalProperties": true
              }
            ]
          }
        }
      }
    }
  }
}
